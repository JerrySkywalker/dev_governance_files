{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-health-process-envelope.v2",
  "type": "object",
  "required": ["schema", "run_id", "wave", "step", "role", "scope", "admitted_head", "outcome", "product_repository_write", "git_mutation", "sanitized_summary", "blocker_fingerprint", "secrets_visible", "private_connection_metadata_count"],
  "properties": {
    "schema": {"const": "repo-health-process-envelope.v2"},
    "run_id": {"type": "string"}, "wave": {"type": "string"}, "step": {"type": "string"},
    "role": {"enum": ["Architect", "Implementer", "Supervisor", "Auditor", "Mechanical"]},
    "scope": {"type": "string"}, "admitted_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "outcome": {"type": "string"}, "product_repository_write": {"type": "boolean"}, "git_mutation": {"type": "boolean"},
    "sanitized_summary": {"type": "string", "minLength": 1}, "blocker_fingerprint": {"type": "string"},
    "secrets_visible": {"const": false}, "private_connection_metadata_count": {"const": 0}
  },
  "additionalProperties": false
}
