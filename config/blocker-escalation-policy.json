{
  "schema": "repo-health-blocker-escalation-policy.v1",
  "fingerprint_fields": [
    "repository_or_scope",
    "phase",
    "finite_classification",
    "failing_contract",
    "normalized_exit_code",
    "source_head_sha_when_applicable",
    "safe_path_digest_when_applicable"
  ],
  "forbidden_fingerprint_fields": [
    "raw_stderr",
    "command_line",
    "environment_values",
    "private_paths",
    "token_like_material",
    "private_connection_metadata"
  ],
  "rounds": {
    "1": "ARCHITECT_FIRST_ANALYSIS",
    "2": "ARCHITECT_PLUS_ADVERSARIAL_AUDIT",
    "3": "HUMAN_REQUIRED_SAME_BLOCKER_THREE_TIMES"
  },
  "immediate_human_required_classes": [
    "REAL_SECRET",
    "IDENTITY_OR_SIGNING_MATERIAL",
    "MFA_OR_PHYSICAL_DEVICE",
    "PRODUCTION_MUTATION",
    "IRREVERSIBLE_DATA_OPERATION",
    "FORCE_PUSH",
    "UNIQUE_COMMITS_UNCLEAR_OWNERSHIP",
    "UNTRACKED_EVIDENCE_RISK",
    "ACTIVE_WORKTREE_UNPROVEN_OWNERSHIP",
    "ACTIVE_PROCESS_DEPENDENCY_UNCLASSIFIED"
  ]
}
